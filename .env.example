# Copia a .env para desarrollo local. En producción esta variable se pasa
# como variable de entorno de build (la fija deploy.sh), porque Astro la
# hornea en el JS del cliente al compilar (prefijo PUBLIC_).
# OJO: si falta en el build, el formulario /empezar no puede enviar pedidos.

# URL de la API de arianet-crm que recibe el formulario /empezar.
# Local: el servidor Go en marcha con `go run ./cmd/server` (ver arianet-crm/README.md).
# Producción: https://api.arianet.eu
PUBLIC_API_URL=http://localhost:8090

# Site key (pública) de Cloudflare Turnstile — anti-spam del formulario /empezar.
# En producción la fija deploy.sh. En dev, si la dejas vacía, el widget no
# aparece y la API no exige el reto (SMTP_SECRET vacío). El secret va en la API.
PUBLIC_TURNSTILE_SITE_KEY=

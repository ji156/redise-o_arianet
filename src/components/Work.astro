---
import { WORK_INTRO, work } from '../data/copy.ts';
---

<section id="trabajo" class="section">
  <div class="head" data-reveal>
    <div>
      <div class="head__label">{WORK_INTRO.label}</div>
      <h2 class="head__h2" data-en={WORK_INTRO.h2.en}>{WORK_INTRO.h2.es}</h2>
    </div>
    <p class="head__para" data-en={WORK_INTRO.para.en}>{WORK_INTRO.para.es}</p>
  </div>

  <div class="swipe-hint" aria-hidden="true" data-en={WORK_INTRO.swipe.en}>
    {WORK_INTRO.swipe.es}
  </div>

  <div class="rail" tabindex="0" role="region" aria-label="Proyectos">
    {
      work.map((w) => (
        <a href={w.url} target="_blank" rel="noopener noreferrer" class="tile" data-reveal>
          <div class="tile__media">
            <img src={w.image} alt={w.title} width="1200" height="675" class="tile__img" loading="lazy" />
          </div>
          <div class="tile__body">
            <span class="tile__tag" data-en={w.tag.en}>
              {w.tag.es}
            </span>
            <h3 class="tile__title">{w.title}</h3>
            <p class="tile__desc" data-en={w.desc.en}>
              {w.desc.es}
            </p>
          </div>
        </a>
      ))
    }
  </div>
</section>

<style>
  .section {
    border-bottom: var(--line-primary);
  }

  .head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 54px var(--gutter) 40px;
    gap: 24px;
    flex-wrap: wrap;
  }

  .head__label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--blue);
    margin-bottom: 18px;
  }

  .head__h2 {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(40px, 6vw, 78px);
    line-height: 0.9;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  .head__para {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    max-width: 330px;
    color: var(--grey-body);
  }

  .swipe-hint {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--grey-muted);
    padding: 0 var(--gutter) 14px;
  }

  /* --- fila horizontal tipo estantería, misma pinta con 3 o con 100 --- */
  .rail {
    display: flex;
    gap: 22px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    padding: 0 var(--gutter) 54px;
    border-top: var(--line-primary);
    padding-top: 40px;
  }

  .tile {
    flex: 0 0 300px;
    scroll-snap-align: start;
    text-decoration: none;
    color: var(--ink);
    border: var(--line-primary);
    background: var(--paper);
    transition: transform 0.2s ease;
  }

  .tile:hover,
  .tile:focus-visible {
    transform: translateY(-4px);
  }

  .tile__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--ink);
    border-bottom: var(--line-primary);
  }

  .tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(1) contrast(1.05);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), filter 0.4s ease;
  }

  .tile:hover .tile__img,
  .tile:focus-visible .tile__img {
    transform: scale(1.05);
    filter: grayscale(0) contrast(1);
  }

  .tile__body {
    padding: 16px 18px 20px;
  }

  .tile__tag {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--blue);
  }

  .tile__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 19px;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin-top: 8px;
  }

  .tile__desc {
    font-family: var(--font-body);
    font-size: 13.5px;
    line-height: 1.45;
    color: var(--grey-body);
    margin-top: 8px;
  }

  /* --- responsive --- */
  @media (max-width: 600px) {
    .head {
      padding: 40px 20px 28px;
    }
    .swipe-hint {
      padding: 0 20px 14px;
    }
    .rail {
      padding: 32px 20px 40px;
    }
    .tile {
      flex-basis: 78%;
    }
  }
</style>

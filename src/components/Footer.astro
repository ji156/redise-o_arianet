---
import { BRAND, FOOTER, CONTACT } from '../data/copy.ts';
---

<footer class="footer">
  <div class="footer__top">
    <a href="#top" class="footer__brand" aria-label={`${BRAND} — inicio`}>
      <img src="/logo-app.png" alt={BRAND} width="34" height="34" class="footer__logo" />
      <span class="footer__wordmark">{BRAND}</span>
    </a>

    <div class="footer__cols">
      <div class="footer__col">
        <span class="footer__heading" data-en={FOOTER.studioCol.heading.en}>
          {FOOTER.studioCol.heading.es}
        </span>
        {
          FOOTER.studioCol.links.map((l) => (
            <a href={l.href} class="footer__link" data-en={l.label.en}>
              {l.label.es}
            </a>
          ))
        }
      </div>

      <div class="footer__col">
        <span class="footer__heading" data-en={FOOTER.contactCol.heading.en}>
          {FOOTER.contactCol.heading.es}
        </span>
        <a href={`mailto:${CONTACT.email}`} class="footer__link">{CONTACT.email}</a>
      </div>

      <div class="footer__col">
        <span class="footer__heading" data-en={FOOTER.legalCol.heading.en}>
          {FOOTER.legalCol.heading.es}
        </span>
        {
          FOOTER.legalCol.links.map((l) => (
            <a href={l.href} class="footer__link" data-en={l.label.en}>
              {l.label.es}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <span data-en={FOOTER.copyright.en}>{FOOTER.copyright.es}</span>
    <span data-en={FOOTER.built.en}>{FOOTER.built.es}</span>
  </div>
</footer>

<style>
  .footer {
    padding: var(--gutter);
  }

  .footer__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 30px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--hairline);
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--ink);
  }

  .footer__logo {
    width: 34px;
    height: 34px;
    border-radius: 8px; /* única esquina redondeada */
  }

  .footer__wordmark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 22px;
  }

  .footer__cols {
    display: flex;
    flex-wrap: wrap;
    gap: 48px;
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__heading {
    color: var(--grey-muted);
    letter-spacing: 0.06em;
  }

  .footer__link {
    text-decoration: none;
    color: var(--ink);
    transition: color 0.15s;
  }

  .footer__link:hover,
  .footer__link:focus-visible {
    color: var(--blue);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    padding-top: 24px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--grey-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* --- responsive --- */
  @media (max-width: 600px) {
    .footer {
      padding: 32px 20px;
    }
    .footer__cols {
      gap: 32px;
    }
  }
</style>
